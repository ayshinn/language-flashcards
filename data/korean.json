    { "id": "ko-163", "en": "May I see the menu?", "es": "메뉴 볼 수 있을까요?\nMenuyu bol su isseulkkayo?", "level": 3, "topic": "requests" },
    { "id": "ko-164", "en": "Is it possible to...?", "es": "...가능한가요?\n...ganeunghangayo?", "level": 3, "topic": "requests" },
    { "id": "ko-165", "en": "May I have...?", "es": "...주시겠어요?\n...jusigesseoyo?", "level": 3, "topic": "requests" },
    { "id": "ko-166", "en": "I'd like to order", "es": "주문할게요\nJumunhalgeyo", "level": 3, "topic": "requests" },
    { "id": "ko-167", "en": "May I pay with card?", "es": "카드로 결제 가능한가요?\nKadeuro gyeolje ganeunghangayo?", "level": 3, "topic": "requests" },
    { "id": "ko-168", "en": "Can I have the bill, please?", "es": "계산서 주세요\nGyesanseo juseyo", "level": 3, "topic": "requests" },
    { "id": "ko-169", "en": "May I sit here?", "es": "여기 앉아도 될까요?\nYeogi anjado doelkkayo?", "level": 3, "topic": "requests" },
    { "id": "ko-170", "en": "Would you mind...?", "es": "...괜찮으세요?\n...gwaenchaneuseyo?", "level": 3, "topic": "requests" },

    { "id": "ko-171", "en": "What do you recommend?", "es": "뭘 추천하세요?\nMwol chucheonhaseyo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-172", "en": "What's the most popular?", "es": "제일 인기 있는 게 뭐예요?\nJeil ingi inneun ge mwoyeyo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-173", "en": "Which is better?", "es": "어느 게 더 좋아요?\nEoneu ge deo joayo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-174", "en": "Do you know a good restaurant?", "es": "좋은 식당 아세요?\nJoeun sikdang aseyo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-175", "en": "Do you have any suggestions?", "es": "추천할 게 있으세요?\nChucheonhal ge isseuseyo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-176", "en": "Where do locals eat?", "es": "현지인들은 어디서 먹어요?\nHyeonjiin deureun eodiseo meogeoyo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-177", "en": "What's the house specialty?", "es": "이 집 대표 메뉴가 뭐예요?\nI jip daepyo menyuga mwoyeyo?", "level": 3, "topic": "recommendations" },
    { "id": "ko-178", "en": "Is it worth visiting?", "es": "가볼 만해요?\nGabol manhaeyo?", "level": 3, "topic": "recommendations" },

    { "id": "ko-179", "en": "I'm allergic to nuts", "es": "견과류 알레르기가 있어요\nGyeongwaryu allereugi ga isseoyo", "level": 3, "topic": "dietary" },
    { "id": "ko-180", "en": "I'm allergic to shellfish", "es": "조개류 알레르기가 있어요\nJogaeryu allereugi ga isseoyo", "level": 3, "topic": "dietary" },
    { "id": "ko-181", "en": "I don't eat meat", "es": "고기를 안 먹어요\nGogireul an meogeoyo", "level": 3, "topic": "dietary" },
    { "id": "ko-182", "en": "I'm vegetarian", "es": "채식주의자예요\nChaesikjuuijayeyo", "level": 3, "topic": "dietary" },
    { "id": "ko-183", "en": "No dairy, please", "es": "유제품 빼 주세요\nYujepum bbae juseyo", "level": 3, "topic": "dietary" },
    { "id": "ko-184", "en": "Is this gluten free?", "es": "이거 글루텐 없나요?\nIgeo geulluten eomnayo?", "level": 3, "topic": "dietary" },
    { "id": "ko-185", "en": "Does this have peanuts?", "es": "이거 땅콩 들어가요?\nIgeo ddangkong deureogayo?", "level": 3, "topic": "dietary" },
    { "id": "ko-186", "en": "I can't eat spicy food", "es": "매운 음식 못 먹어요\nMaeun eumsik mot meogeoyo", "level": 3, "topic": "dietary" },

    { "id": "ko-187", "en": "How do I get to...?", "es": "...에 어떻게 가요?\n...e eoddeoke gayo?", "level": 3, "topic": "transit" },
    { "id": "ko-188", "en": "Take me to this address", "es": "이 주소로 가 주세요\nI jusoro ga juseyo", "level": 3, "topic": "transit" },
    { "id": "ko-189", "en": "Please use the meter", "es": "미터기 켜 주세요\nMitegi kyeo juseyo", "level": 3, "topic": "transit" },
    { "id": "ko-190", "en": "How long does it take?", "es": "얼마나 걸려요?\nEolmana geollyeoyo?", "level": 3, "topic": "transit" },
    { "id": "ko-191", "en": "Which line goes to...?", "es": "...에 가는 몇 호선이에요?\n...e ganeun myeot hoseonieyo?", "level": 3, "topic": "transit" },
    { "id": "ko-192", "en": "Is this the right stop?", "es": "이번 역이 맞아요?\nIbeon yeogi majayo?", "level": 3, "topic": "transit" },
    { "id": "ko-193", "en": "To the airport, please", "es": "공항으로 가 주세요\nGonghangeuro ga juseyo", "level": 3, "topic": "transit" },
    { "id": "ko-194", "en": "Can you wait a moment?", "es": "잠깐만요\nJamkkanmanyo", "level": 3, "topic": "transit" },
    { "id": "ko-195", "en": "Drop me at the corner", "es": "모퉁이에서 내려 주세요\nMotungieseo naeryeo juseyo", "level": 3, "topic": "transit" },
    { "id": "ko-196", "en": "That's not the right way", "es": "그 길이 아닌데요\nGeu giri anindeyo", "level": 3, "topic": "transit" },

    { "id": "ko-197", "en": "This isn't what I ordered", "es": "제가 주문한 게 아닌데요\nJega jumonhan ge anindeyo", "level": 3, "topic": "problems" },
    { "id": "ko-198", "en": "The bill is wrong", "es": "계산이 잘못된 것 같아요\nGyesani jalmotdoen geot gatayo", "level": 3, "topic": "problems" },
    { "id": "ko-199", "en": "This food is cold", "es": "음식이 식었어요\nEumsigi sigeosseoyo", "level": 3, "topic": "problems" },
    { "id": "ko-200", "en": "I've been waiting a long time", "es": "오래 기다렸어요\nOrae gidaryeosseoyo", "level": 3, "topic": "problems" },
    { "id": "ko-201", "en": "The wifi isn't working", "es": "와이파이가 안 돼요\nWaipai ga an dwaeyo", "level": 3, "topic": "problems" },
    { "id": "ko-202", "en": "I lost my phone", "es": "핸드폰을 잃어버렸어요\nHaendeupon eul ilheobeoryeosseoyo", "level": 3, "topic": "problems" },
    { "id": "ko-203", "en": "My room is too noisy", "es": "방이 너무 시끄러워요\nBangi neomu sikkeurowoyo", "level": 3, "topic": "problems" },
    { "id": "ko-204", "en": "The AC isn't working", "es": "에어컨이 안 돼요\nEeokoni an dwaeyo", "level": 3, "topic": "problems" },

    { "id": "ko-205", "en": "Where are you from?", "es": "어디서 오셨어요?\nEodiseo osyeosseoyo?", "level": 3, "topic": "smalltalk" },
    { "id": "ko-206", "en": "I'm from the United States", "es": "미국에서 왔어요\nMigugeseo wasseoyo", "level": 3, "topic": "smalltalk" },
    { "id": "ko-207", "en": "How long have you lived here?", "es": "여기 사신 지 얼마나 됐어요?\nYeogi sasin ji eolmana dwaesseoyo?", "level": 3, "topic": "smalltalk" },
    { "id": "ko-208", "en": "This is my first time in Korea", "es": "한국은 처음이에요\nHangukeun cheoeumeyo", "level": 3, "topic": "smalltalk" },
    { "id": "ko-209", "en": "Korea is beautiful", "es": "한국이 아름다워요\nHanguki areumdawoyo", "level": 3, "topic": "smalltalk" },
    { "id": "ko-210", "en": "The food is delicious", "es": "음식이 맛있어요\nEumsigi masisseoyo", "level": 3, "topic": "smalltalk" },
    { "id": "ko-211", "en": "You speak English very well", "es": "영어 잘 하시네요\nYeongeo jal hasineyo", "level": 3, "topic": "smalltalk" },
    { "id": "ko-212", "en": "What's your favorite place?", "es": "좋아하는 곳이 어디예요?\nJoahaneun gosi eodiyeyo?", "level": 3, "topic": "smalltalk" },
    { "id": "ko-213", "en": "Do you have any tips?", "es": "조언해 줄 수 있어요?\nJoeonhae jul su isseoyo?", "level": 3, "topic": "smalltalk" },
    { "id": "ko-214", "en": "Thank you for your help", "es": "도와줘서 감사해요\nDowajwoseo gamsahaeyo", "level": 3, "topic": "smalltalk" },

    { "id": "ko-215", "en": "What time does it open?", "es": "몇 시에 열어요?\nMyeot sie yeoleoyo?", "level": 3, "topic": "time" },
    { "id": "ko-216", "en": "What time does it close?", "es": "몇 시에 닫아요?\nMyeot sie dadayo?", "level": 3, "topic": "time" },
    { "id": "ko-217", "en": "What time is it?", "es": "지금 몇 시예요?\nJigeum myeot siyeyo?", "level": 3, "topic": "time" },
    { "id": "ko-218", "en": "How long?", "es": "얼마나요?\nEolmanayo?", "level": 3, "topic": "time" },
    { "id": "ko-219", "en": "Today at noon", "es": "오늘 정오에\nOneul jeongoe", "level": 3, "topic": "time" },
    { "id": "ko-220", "en": "Tomorrow morning", "es": "내일 아침에\nNaeil achime", "level": 3, "topic": "time" },
    { "id": "ko-221", "en": "In an hour", "es": "한 시간 후에\nHan sigan hue", "level": 3, "topic": "time" },
    { "id": "ko-222", "en": "At what time?", "es": "몇 시에요?\nMyeot siyeyo?", "level": 3, "topic": "time" },

    { "id": "ko-223", "en": "Where is the museum?", "es": "박물관이 어디 있어요?\nBakmurkwani eodi isseoyo?", "level": 3, "topic": "sights" },
    { "id": "ko-224", "en": "Is there an entrance fee?", "es": "입장료가 있어요?\nIpjangnyo ga isseoyo?", "level": 3, "topic": "sights" },
    { "id": "ko-225", "en": "Do you have a map?", "es": "지도 있어요?\nJido isseoyo?", "level": 3, "topic": "sights" },
    { "id": "ko-226", "en": "Can I take a photo?", "es": "사진 찍어도 돼요?\nSajin jjigeodo dwaeyo?", "level": 3, "topic": "sights" },
    { "id": "ko-227", "en": "Is it open today?", "es": "오늘 열어요?\nOneul yeoleoyo?", "level": 3, "topic": "sights" },
    { "id": "ko-228", "en": "The line is very long", "es": "줄이 너무 길어요\nJuri neomu gireoyo", "level": 3, "topic": "sights" },

    { "id": "ko-229", "en": "Where is the ATM?", "es": "ATM이 어디 있어요?\nATMi eodi isseoyo?", "level": 3, "topic": "money" },
    { "id": "ko-230", "en": "Do you have change?", "es": "잔돈 있어요?\nJandon isseoyo?", "level": 3, "topic": "money" },
    { "id": "ko-231", "en": "Can I withdraw money here?", "es": "여기서 돈 뽑을 수 있어요?\nYeogiseo don bbobeul su isseoyo?", "level": 3, "topic": "money" },
    { "id": "ko-232", "en": "The ATM kept my card", "es": "ATM이 카드를 먹었어요\nATMi kadeureul meogosseoyo", "level": 3, "topic": "money" },
    { "id": "ko-233", "en": "Can you break this bill?", "es": "이 지폐를 바꿔 주실 수 있어요?\nI jipyereul bakkwo jusil su isseoyo?", "level": 3, "topic": "money" },
    { "id": "ko-234", "en": "Only small bills, please", "es": "소액권으로 주세요\nSoaekgwoneuro juseyo", "level": 3, "topic": "money" },

    { "id": "ko-235", "en": "Call the police", "es": "경찰에 신고해 주세요\nGyeongchare singohae juseyo", "level": 3, "topic": "emergency" },
    { "id": "ko-236", "en": "I need a doctor", "es": "의사가 필요해요\nUisaga piryohaeyo", "level": 3, "topic": "emergency" },
    { "id": "ko-237", "en": "Where is the hospital?", "es": "병원이 어디 있어요?\nByeongwoni eodi isseoyo?", "level": 3, "topic": "emergency" },
    { "id": "ko-238", "en": "I lost my wallet", "es": "지갑을 잃어버렸어요\nJigabeul ilheobeoryeosseoyo", "level": 3, "topic": "emergency" },
    { "id": "ko-239", "en": "I was robbed", "es": "강도를 당했어요\nGangdoreul danghaesseoyo", "level": 3, "topic": "emergency" },
    { "id": "ko-240", "en": "Where is the embassy?", "es": "대사관이 어디 있어요?\nDaesagwani eodi isseoyo?", "level": 3, "topic": "emergency" }
  ]
}
